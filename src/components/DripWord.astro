---
// Cada letra recibe su propio goteo usando la imagen de referencia real
// (gotas-mask.png) como máscara, con un trozo distinto por letra (posición y
// largo variados) para que se vean gotas orgánicas, no repetidas.
interface Props {
  text: string;
  color?: string;
  scale?: number; // multiplica el largo de las gotas
  class?: string;
}
const {
  text,
  color = "var(--accent)",
  scale = 1,
  class: className = "",
} = Astro.props;

const chars = [...text];
const posX = [6, 54, 30, 82, 16, 68, 42, 92, 22, 60, 38];
const lens = [0.95, 1.3, 0.7, 1.15, 0.82, 1.35, 0.75, 1.05, 0.9, 1.2];
---

<span class={`drip-word ${className}`} style={`--dc:${color}`}>
  {
    chars.map((ch, i) =>
      ch === " " ? (
        <span class="drip-space">&#160;</span>
      ) : (
        <span class="drip-letter">
          {ch}
          <i
            class="letter-drip"
            style={`--mx:${posX[i % posX.length]}%; --dh:${(lens[i % lens.length] * scale).toFixed(2)}em`}
            aria-hidden="true"
          />
        </span>
      ),
    )
  }
</span>
