---
import { business, waLink, directionsLink } from "../lib/business";
const year = new Date().getFullYear();
---

<footer class="relative border-t border-white/10 bg-[var(--bg)] px-5 py-14 md:px-10">
  <div class="mx-auto flex max-w-6xl flex-col gap-10 md:flex-row md:justify-between">
    <div class="max-w-xs">
      <div class="flex items-center gap-3">
        <img src="/logo.png" alt="2K16 Barber Shop — barbería en Luque" class="h-14 w-14 object-contain" />
        <span class="display text-2xl text-white">2K16 Barber Shop</span>
      </div>
      <p class="mt-4 text-sm leading-relaxed text-white/50">
        Barbería en Luque, Paraguay. Cortes, barba y afeitado clásico con estilo street.
      </p>
      <a
        href={business.mapsPlace}
        target="_blank"
        rel="noopener"
        class="mt-4 inline-flex items-start gap-2 text-sm text-white/60 transition-colors hover:text-[var(--accent)]"
      >
        <span aria-hidden="true">📍</span>
        <span>{business.street}<br />{business.city}, Paraguay</span>
      </a>
    </div>

    <div class="grid grid-cols-2 gap-8 text-sm">
      <div>
        <h4 class="mb-3 text-xs uppercase tracking-widest text-[var(--accent)]">Horarios</h4>
        <ul class="space-y-1 text-white/60">
          {business.hours.map((h) => <li>{h.d} · {h.h}</li>)}
        </ul>
      </div>
      <div>
        <h4 class="mb-3 text-xs uppercase tracking-widest text-[var(--accent)]">Contacto</h4>
        <ul class="space-y-2 text-white/60">
          {
            business.phones.map((p) => (
              <li>
                <a
                  href={waLink(p.wa)}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 hover:text-white"
                >
                  <span aria-hidden="true">💬</span> {p.e164}
                </a>
              </li>
            ))
          }
          <li>
            <a
              href={directionsLink}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 hover:text-white"
            >
              <span aria-hidden="true">🧭</span> Cómo llegar
            </a>
          </li>
          <li><a href="#reserva" class="hover:text-white">Reservar turno</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="mx-auto mt-12 max-w-6xl border-t border-white/5 pt-6 text-xs text-white/30">
    © {year} 2K16 Barber Shop · Luque, Paraguay. Todos los derechos reservados.
  </div>
</footer>
