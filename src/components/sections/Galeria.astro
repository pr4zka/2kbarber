---
import GraffitiTitle from "../GraffitiTitle.astro";

// Muro estilo graffiti — placeholders "Próximamente" (sin fotos por ahora).
const tiles = [
  { span: "md:row-span-2", tag: "Fade" },
  { span: "", tag: "Barba" },
  { span: "", tag: "Diseño" },
  { span: "md:row-span-2", tag: "Clásico" },
  { span: "", tag: "Combo" },
  { span: "", tag: "Color" },
];
---

<section id="galeria" class="relative overflow-hidden bg-[var(--bg)] py-24">
  <div class="spray-deco right-[2%] top-[8%] h-72 w-72 rotate-[10deg]"></div>

  <div class="relative px-5 md:px-10">
    <p class="font-tag text-base tracking-wide text-[var(--accent)]">// el muro</p>
    <h2 class="display -skew-x-6 text-6xl md:text-8xl">
      <GraffitiTitle text="Galería" color="var(--accent)" dripScale={0.7} />
    </h2>
    <p class="mt-4 max-w-md text-sm text-white/50">
      Pronto: nuestros mejores trabajos. Mientras tanto, reservá tu lugar.
    </p>
  </div>

  <div
    class="relative mt-12 grid auto-rows-[200px] grid-cols-2 gap-3 px-5 md:grid-cols-3 md:px-10"
  >
    {
      tiles.map((t) => (
        <div
          data-reveal
          class={`group relative flex flex-col justify-between overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-br from-[var(--surface,#141414)] to-black ${t.span}`}
        >
          <div class="absolute inset-0 bg-[var(--accent)] opacity-0 mix-blend-overlay transition-opacity duration-500 group-hover:opacity-10" />
          <span class="absolute right-4 top-4 z-10 rounded-full bg-black/50 px-3 py-1 text-[0.6rem] uppercase tracking-widest text-[var(--accent)] backdrop-blur">
            2K
          </span>
          <span class="font-tag relative z-10 mt-auto px-5 pt-5 text-3xl text-white/80">
            {t.tag}
          </span>
          <span class="relative z-10 px-5 pb-5 text-[0.65rem] uppercase tracking-[0.3em] text-white/30">
            Próximamente
          </span>
        </div>
      ))
    }
  </div>
</section>
