---
// Formulario de reserva — envía nombre, correo, número al backend.
import GraffitiTitle from "../GraffitiTitle.astro";
import { business, waLink } from "../../lib/business";
---

<section
  id="reserva"
  class="relative overflow-hidden bg-[var(--bg-deep,#050505)] py-28"
>
  <div
    class="pointer-events-none absolute left-1/2 top-0 h-72 w-72 -translate-x-1/2 rounded-full bg-[var(--accent)] opacity-20 blur-[120px]"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-xl px-6 text-center">
    <p class="font-tag text-base tracking-wide text-[var(--accent)]">// tu lugar te espera</p>
    <h2 class="display mx-auto mt-2 -skew-x-6 text-5xl leading-[1.1] md:text-7xl">
      <GraffitiTitle text="Reservá" color="#ffffff" dripScale={0.45} />
      <br />
      <GraffitiTitle text="tu turno" color="var(--accent)" dripScale={0.8} />
    </h2>
    <p class="mt-4 text-sm text-white/60">
      Dejanos tus datos y te confirmamos el turno. Simple, rápido, sin vueltas.
    </p>

    <form id="reserva-form" class="mt-10 flex flex-col gap-4 text-left" novalidate>
      <div>
        <label for="nombre" class="mb-1.5 block text-xs uppercase tracking-widest text-white/50"
          >Nombre</label
        >
        <input
          id="nombre"
          name="nombre"
          type="text"
          autocomplete="name"
          placeholder="Tu nombre"
          required
          class="w-full rounded-xl border border-white/15 bg-white/5 px-4 py-3.5 text-white placeholder:text-white/30 outline-none transition-colors focus:border-[var(--accent)]"
        />
      </div>

      <div>
        <label for="correo" class="mb-1.5 block text-xs uppercase tracking-widest text-white/50"
          >Correo</label
        >
        <input
          id="correo"
          name="correo"
          type="email"
          autocomplete="email"
          placeholder="tucorreo@mail.com"
          required
          class="w-full rounded-xl border border-white/15 bg-white/5 px-4 py-3.5 text-white placeholder:text-white/30 outline-none transition-colors focus:border-[var(--accent)]"
        />
      </div>

      <div>
        <label for="numero" class="mb-1.5 block text-xs uppercase tracking-widest text-white/50"
          >Número</label
        >
        <input
          id="numero"
          name="numero"
          type="tel"
          autocomplete="tel"
          placeholder="+595 9xx xxx xxx"
          required
          class="w-full rounded-xl border border-white/15 bg-white/5 px-4 py-3.5 text-white placeholder:text-white/30 outline-none transition-colors focus:border-[var(--accent)]"
        />
      </div>

      <div>
        <span class="mb-2 block text-xs uppercase tracking-widest text-white/50">Elegí el día</span>
        <div id="cal" class="rounded-2xl border border-white/15 bg-white/5 p-4"></div>
      </div>

      <div>
        <span class="mb-2 block text-xs uppercase tracking-widest text-white/50">Elegí la hora</span>
        <div id="slots" class="flex flex-wrap gap-2">
          <span class="text-sm text-white/30">Elegí un día para ver los horarios disponibles.</span>
        </div>
      </div>

      <input type="hidden" name="fecha" id="fecha" />
      <input type="hidden" name="hora" id="hora" />

      <button
        type="submit"
        id="reserva-submit"
        class="mt-2 rounded-full bg-[var(--accent)] px-8 py-4 text-sm font-bold uppercase tracking-widest text-black transition-transform hover:scale-[1.02] disabled:cursor-not-allowed disabled:opacity-60"
      >
        Confirmar turno
      </button>

      <p
        id="reserva-msg"
        class="min-h-[1.25rem] text-center text-sm"
        role="status"
        aria-live="polite"
      >
      </p>
    </form>

    <!-- Contacto directo por WhatsApp -->
    <div class="mt-14 border-t border-white/10 pt-10">
      <p class="text-xs uppercase tracking-widest text-white/40">¿Preferís escribirnos?</p>
      <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:justify-center">
        {
          business.phones.map((p) => (
            <a
              href={waLink(p.wa)}
              target="_blank"
              rel="noopener"
              class="flex items-center justify-center gap-2 rounded-full border border-[#25D366]/40 bg-[#25D366]/10 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-[#25D366] hover:text-black"
            >
              <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
                <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.738-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z" />
              </svg>
              {p.e164}
            </a>
          ))
        }
      </div>
    </div>

    <!-- Ubicación -->
    <div class="mt-12 text-center">
      <p class="font-tag text-base tracking-wide text-[var(--accent)]">// dónde estamos</p>
      <a
        href={business.mapsPlace}
        target="_blank"
        rel="noopener"
        class="mt-2 inline-flex items-center gap-2 text-sm text-white/70 transition-colors hover:text-white"
      >
        <span aria-hidden="true">📍</span> {business.street}, {business.city}, Paraguay
      </a>
      <div class="mt-6 overflow-hidden rounded-2xl border border-white/10">
        <iframe
          title="Ubicación de 2K16 Barber Shop en Google Maps"
          src={`https://www.google.com/maps?q=${business.lat},${business.lng}&z=17&output=embed`}
          width="100%"
          height="320"
          style="border:0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen></iframe>
      </div>
    </div>
  </div>
</section>
